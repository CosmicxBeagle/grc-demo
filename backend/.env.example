# Copy this to .env and fill in real values
# NEVER commit .env to git

DATABASE_URL=postgresql://grc:changeme@localhost:5432/grc_demo
EVIDENCE_UPLOAD_DIR=./data/evidence
CORS_ORIGINS=http://localhost:3002
APP_NAME=GRC Demo
APP_ENV=local
DEBUG=false
DEMO_AUTH_ENABLED=false
ENABLE_API_DOCS=true
SESSION_SECRET=change-me-local-dev-session-secret
SESSION_COOKIE_NAME=session
SESSION_TIMEOUT_MINUTES=60
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
SCIM_TOKEN=

# ── Azure AD / Entra ID ──────────────────────────────────────────────────────
# Leave these BLANK for local demo mode (username-only login bypass)
# Fill them in to enable real Entra ID SSO
#
# Setup steps:
#   1. Go to portal.azure.com → Azure Active Directory → App Registrations
#   2. New registration → Name: "GRC App", Redirect URI: http://localhost:3002
#   3. Note the Application (client) ID and Directory (tenant) ID
#   4. Expose an API → Add a scope named "GRC.Access"
#   5. App Roles → Add: GRC.Admin, GRC.Tester, GRC.Reviewer
#   6. Assign users/groups to roles in Enterprise Applications
#
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_AUDIENCE=

# Azure Key Vault — for production secrets
# AZURE_KEYVAULT_URL=https://your-kv.vault.azure.net/

# Okta OIDC redirect flow placeholders
OKTA_DOMAIN=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_AUDIENCE=api://default
OKTA_REDIRECT_URI=
OKTA_SCOPES=openid profile email
