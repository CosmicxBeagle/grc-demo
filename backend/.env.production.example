# ─────────────────────────────────────────────────────────────────────────────
# GRC Demo — Production Environment Variables
#
# Copy this file to .env on your deployment host (or inject as container env
# vars / Key Vault references).  Every variable marked REQUIRED must be set
# before the app will start in production.  Variables marked RECOMMENDED have
# safe defaults but should be explicitly set for clarity.
#
# DO NOT commit the real .env file.  Store secrets in Azure Key Vault or your
# secret manager and inject them at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime environment ───────────────────────────────────────────────────────
# REQUIRED.  Enables security guards: strict cookie flags, docs lockdown,
# session-secret validation, and demo-auth enforcement.
APP_ENV=production

APP_NAME=GRC Demo

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED.  Use PostgreSQL in production — SQLite is local-dev only.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Managed identity example (Azure):  postgresql://grc@host/grc_demo?sslmode=require
DATABASE_URL=postgresql://grc:CHANGE_ME@your-db-host:5432/grc_demo

# ── Session security ──────────────────────────────────────────────────────────
# REQUIRED.  Must be a randomly-generated string of ≥32 characters.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Store in Key Vault — never commit this value.
SESSION_SECRET=CHANGE_ME_generate_with_secrets_token_urlsafe_48

# Session timeout in minutes (default 60).  Sliding window — resets on activity.
SESSION_TIMEOUT_MINUTES=60

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED.  Must be false in production.  demo auth allows login with any
# username and no password — it is a development convenience only.
# The app will refuse to start if APP_ENV=production and this is true.
DEMO_AUTH_ENABLED=false

# Disable interactive API docs (Swagger UI / ReDoc) in production.
ENABLE_API_DOCS=false

# ── Azure AD / Entra ID SSO (optional — leave blank to disable) ───────────────
# Register a backend app and a frontend SPA app in your Azure tenant.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_AUDIENCE=

# ── Okta SSO (optional — leave blank to disable) ──────────────────────────────
OKTA_DOMAIN=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_AUDIENCE=api://default
OKTA_REDIRECT_URI=
OKTA_SCOPES=openid profile email

# ── CORS ─────────────────────────────────────────────────────────────────────
# REQUIRED.  Set to EXACTLY your production frontend origin.
# Must NOT contain localhost or wildcard (*).
# Example:  https://grc.yourcompany.com
CORS_ORIGINS=https://grc.yourcompany.com

# ── Application base URL ──────────────────────────────────────────────────────
# REQUIRED.  Used to build links in outbound emails (review requests, reminders).
# Must match the public URL users visit.
APP_BASE_URL=https://grc.yourcompany.com

# ── Evidence storage ──────────────────────────────────────────────────────────
# Option A — Azure Blob Storage (RECOMMENDED for production).
# The app authenticates via managed identity (no storage account key needed).
# Create a storage account and container in Azure, then set:
AZURE_STORAGE_ACCOUNT=your-storage-account-name
AZURE_STORAGE_CONTAINER=evidence

# Option B — Local filesystem (not recommended for production; data lost on
# container restart unless a persistent volume is mounted).
# Used automatically when AZURE_STORAGE_ACCOUNT is blank.
# EVIDENCE_UPLOAD_DIR=/data/evidence

# ── Email ─────────────────────────────────────────────────────────────────────
# Option A — SMTP relay (store credentials in Key Vault, not here).
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USER=grc-noreply@yourcompany.com
SMTP_PASS=CHANGE_ME
EMAIL_FROM=grc-noreply@yourcompany.com

# Option B — Azure Communication Services / Azure Email Service.
# (Planned: set AZURE_EMAIL_ENDPOINT when integrated.)
# AZURE_EMAIL_ENDPOINT=https://your-comm-service.communication.azure.com

# ── Startup behaviour ─────────────────────────────────────────────────────────
# For scaled / multi-instance deployments set RUN_MIGRATIONS=false and run
# "alembic upgrade head" as a separate CI/CD step before rolling out new pods.
# Leaving it true is fine for single-instance or demo environments.
RUN_MIGRATIONS=false

# Never seed demo users in production.
SEED_DEMO_DATA=false

# Number of uvicorn worker processes.  Rule of thumb: 2 × CPU cores + 1.
UVICORN_WORKERS=4

# ── Observability (optional) ──────────────────────────────────────────────────
# Azure Application Insights connection string.
# Paste the value from your Application Insights resource → "Connection String".
# Leave blank to disable telemetry (structured JSON logs to stdout still work).
APPINSIGHTS_CONNECTION_STRING=
