# Copy to .env.local for local development
# Leave AZURE vars empty for demo mode (username-only login)

# ── Azure AD / Entra ID ──────────────────────────────────────────────────────
# Fill these in to enable Microsoft SSO login
NEXT_PUBLIC_AZURE_CLIENT_ID=
NEXT_PUBLIC_AZURE_TENANT_ID=
NEXT_PUBLIC_AZURE_AUDIENCE=

# Override backend URL (defaults to /api proxy → localhost:8000)
# NEXT_PUBLIC_API_URL=
