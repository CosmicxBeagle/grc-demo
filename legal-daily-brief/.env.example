# ============================================================
# Legal Daily Brief — Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# Your Microsoft 365 / Azure AD credentials
# Register a free app at https://portal.azure.com
#   → Azure Active Directory → App registrations → New registration
#   → Redirect URI: http://localhost:8400  (type: Public client/native)
#   → API permissions: Calendars.Read, Mail.Send
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here

# Which Outlook calendar to read
# Leave blank to use your default/primary calendar
# Or enter the calendar name exactly as it appears in Outlook (e.g. "Legal Deadlines")
OUTLOOK_CALENDAR_NAME=

# How many days ahead to look (default 30)
LOOKAHEAD_DAYS=30

# Your email — daily brief is sent here every morning
YOUR_EMAIL=you@yourlawfirm.com

# What time to send the brief (24-hour, local time)
SEND_TIME=07:00

# Where to save the PDF each day
# Mac:     REPORT_SAVE_PATH=/Users/yourname/Documents/DailyBriefs
# Windows: REPORT_SAVE_PATH=C:\Users\yourname\Documents\DailyBriefs
REPORT_SAVE_PATH=./data/reports

# Prefix used on your Outlook calendar events to mark deadlines
# Change this if you use a different prefix
DEADLINE_PREFIX=DD:

# Your name (shown on the brief header)
YOUR_NAME=
FIRM_NAME=
