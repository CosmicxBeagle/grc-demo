# ============================================================
# Legal Deadline Manager — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=development             # development | production
APP_HOST=127.0.0.1             # NEVER change to 0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
FIRM_NAME=Your Law Firm Name
FIRM_EMAIL=paralegal@yourlawfirm.com

# ── Database ──────────────────────────────────────────────────
# SQLite (default — local file, no server needed)
DATABASE_URL=sqlite:///./data/deadlines.db

# PostgreSQL (optional — uncomment to use)
# DATABASE_URL=postgresql://user:password@localhost:5432/legal_deadlines

# ── Encryption ────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=GENERATE_A_FERNET_KEY_AND_PASTE_HERE

# ── Microsoft Graph API ────────────────────────────────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Set redirect URI to: http://localhost:8000/auth/callback
# Grant permissions: Calendars.ReadWrite, Tasks.ReadWrite, Mail.Send, User.Read

AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
# Leave AZURE_CLIENT_SECRET blank for Public Client (PKCE) flow — recommended
# AZURE_CLIENT_SECRET=only-needed-for-confidential-client

# OAuth scopes needed
GRAPH_SCOPES=Calendars.ReadWrite Tasks.ReadWrite Mail.Send User.Read

# Outlook calendar to sync deadlines to (leave blank to use default calendar)
OUTLOOK_CALENDAR_ID=
# Microsoft To Do task list name for deadlines
TODO_LIST_NAME=Legal Deadlines

# ── Attorney Sheet Email ───────────────────────────────────────
ATTORNEY_EMAIL=attorney@yourlawfirm.com
DAILY_SHEET_TIME=07:00          # Time to generate and email daily sheet (24h, local time)
DAILY_SHEET_SAVE_PATH=./data/reports/

# ── Needles Integration (Phase 3 — optional) ──────────────────
# Only needed if using Needles NX with on-premise SQL Server
NEEDLES_ENABLED=false
NEEDLES_ODBC_CONNECTION_STRING=

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./data/app.log

# ── PDF Generation ────────────────────────────────────────────
# Path to wkhtmltopdf binary (only needed if using wkhtmltopdf backend)
# WKHTMLTOPDF_PATH=C:\Program Files\wkhtmltopdf\bin\wkhtmltopdf.exe
